# ─────────────────────────────────────────────────────────────────────────────
#  solana-hft-botx  ·  .env  (copy to .env and fill in real values)
# ─────────────────────────────────────────────────────────────────────────────

# ── RPC ──────────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Wallets ───────────────────────────────────────────────────────────────────
# Single wallet:
PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY
# OR multi-wallet (comma-separated):
# PRIVATE_KEYS=KEY_ONE,KEY_TWO,KEY_THREE

# ── Optional overrides (all also set in config/default.toml) ─────────────────
# SLIPPAGE_BPS=200
# JITO_TIP_LAMPORTS=15000000
# MAX_SOL_PER_TRADE=500000000
